# ── 서버 ────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
# 쉼표로 구분한 허용 CIDR/IP (사내망). 비우면 전체 차단(로컬 제외).
ALLOWED_NETWORKS=192.168.0.0/16,211.236.0.0/16
ALLOWED_IPS=127.0.0.1,192.168.111.111

# ── 인증 ────────────────────────────────────────────────
# 로그인 허용 이메일 도메인
ALLOWED_EMAIL_DOMAIN=llsollu.com
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=720
# 앱단 비밀 암호화 키 (Fernet, base64 32bytes). 미설정 시 부팅 실패.
SECRET_ENC_KEY=

# ── DB / Redis ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://llsollu:llsollu@postgres:5432/llsollu_email_agent
REDIS_URL=redis://redis:6379/0

# ── LLM (사내 SLM, OpenAI 호환) ────────────────────
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=not-needed
LLM_MAX_CONCURRENCY=4

# ── Microsoft Graph (앱 전용 client credentials) ────────
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
# Graph 구독(webhook) 콜백이 도달할 수 있는 주소. 미설정 시 폴링 모드.
GRAPH_WEBHOOK_BASE_URL=
GRAPH_WEBHOOK_CLIENT_STATE=change-me

# ── 스케줄러 / 폴링 ────────────────────────────────────
SCHEDULER_TZ=Asia/Seoul
MAIL_POLL_INTERVAL_SEC=60
